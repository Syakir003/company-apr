---
import { site } from '../data/site.js';

const { service } = Astro.props;
const waLink = `https://wa.me/${site.waNumber}?text=${encodeURIComponent(`Halo CV Ayub Podo Rukun, saya ingin bertanya tentang ${service.title}.`)}`;
const webpPhoto = service.photo.replace(/\.jpe?g$/i, '.webp');
const PHOTO_DIMS = {
  '/assets/unit5.jpeg': [1920, 1440],
  '/assets/teknisi5.jpeg': [960, 1280],
  '/assets/teknisi7.jpeg': [1920, 1739],
  '/assets/unit7.jpeg': [1920, 1440],
};
const [photoW, photoH] = PHOTO_DIMS[service.photo] ?? [];
const checkIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
const arrowIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>`;
const chevronIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>`;
---

<section class="svc-hero">
  <div class="svc-hero-bg" data-parallax>
    <img src={webpPhoto} onerror={`this.onerror=null;this.src='${service.photo}'`} alt={service.title} fetchpriority="high" decoding="async" width={photoW} height={photoH} />
  </div>
  <div class="svc-hero-scrim"></div>
  <div class="wrap svc-hero-inner">
    <a class="back" href="/#layanan">← Kembali ke Layanan</a>
    <div data-reveal>
      <div class="eyebrow"><span class="tick"></span><span class="mono">{service.n}. {service.title}</span></div>
      <h1>{service.title}</h1>
      <p class="lead">{service.tagline}</p>
      <div class="info">
        <span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Respon cepat
        </span>
        <span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Bergaransi
        </span>
        <span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Teknisi bersertifikat
        </span>
        <span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Area Mojokerto & sekitarnya
        </span>
      </div>
      <a class="btn btn-light" href={waLink} target="_blank" rel="noopener">Konsultasi Gratis →</a>
    </div>
  </div>
</section>

<div class="svc-body">
  <div class="wrap">
    <div class="sec" data-reveal>
      <h2>Tentang Layanan Ini</h2>
      <p>Informasi lengkap seputar {service.title.toLowerCase()} dari CV Ayub Podo Rukun.</p>
      <div class="desc-grid">
        <p>{service.longDesc}</p>
        <p>{service.longDesc2}</p>
      </div>
    </div>

    <div class="sec" data-reveal>
      <h2>Yang Kami Tawarkan</h2>
      <p>Berikut adalah layanan dan fasilitas yang termasuk dalam {service.title.toLowerCase()}.</p>
      <ul class="feature-grid">
        {service.features.map((f) => (
          <li set:html={`${checkIcon} ${f}`} />
        ))}
      </ul>
    </div>

    <div class="sec" data-reveal>
      <h2>Cocok Untuk</h2>
      <p>Layanan ini dirancang untuk memenuhi kebutuhan berbagai segmen pelanggan.</p>
      <ul class="srv-suitable">
        {service.suitableFor.map((s) => (
          <li set:html={`${arrowIcon} ${s}`} />
        ))}
      </ul>
    </div>

    <div class="sec" data-reveal>
      <h2>Tanya Jawab</h2>
      <p>Pertanyaan yang sering diajukan tentang {service.title.toLowerCase()}.</p>
      <div class="svc-faq">
        {service.faq.map((item) => (
          <details>
            <summary>{item.q}<span set:html={chevronIcon} /></summary>
            <div class="faq-a">{item.a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="svc-cta" data-reveal>
      <div>
        <h2>Siap menggunakan layanan kami?</h2>
        <p>Hubungi kami sekarang untuk konsultasi gratis dan penawaran terbaik. Tim kami siap membantu Anda.</p>
      </div>
      <div class="b">
        <a class="btn btn-light" href={waLink} target="_blank" rel="noopener">Chat WhatsApp</a>
        <a class="btn btn-outline" href={waLink} target="_blank" rel="noopener">Hubungi Kami</a>
      </div>
    </div>
  </div>
</div>