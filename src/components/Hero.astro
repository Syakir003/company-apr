---
import { site } from '../data/site.js';
---
<section id="beranda" class="hero">
  <!-- Full-bleed background: crossfade slideshow over the field photos -->
  <div class="hero-bg" data-parallax data-hero-slides>
    <img class="is-active" src="/assets/teknisi1.webp" onerror="this.onerror=null;this.src='/assets/teknisi1.jpeg'" alt="Teknisi service AC industri CV Ayub Podo Rukun di Mojokerto" fetchpriority="high" decoding="async" width="1280" height="960" />
    <!-- Remaining slides carry no src/data URL that the browser can fetch
         until hero-slideshow.js hydrates them after the page has loaded, so
         they don't compete with the LCP image for bandwidth on first load. -->
    <img data-lazy-slide data-src="/assets/unit1.webp" data-fallback="/assets/unit1.jpeg" alt="Armada Ayub AC mengirim unit AC ke lokasi" decoding="async" width="1280" height="960" />
    <img data-lazy-slide data-src="/assets/teknisi2.webp" data-fallback="/assets/teknisi2.jpeg" alt="Tim teknisi memasang unit AC di dinding gedung industri" decoding="async" width="715" height="960" />
    <img data-lazy-slide data-src="/assets/unit2.webp" data-fallback="/assets/unit2.jpeg" alt="Pengiriman unit AC Gree dengan armada Ayub AC" decoding="async" width="960" height="1280" />
    <img data-lazy-slide data-src="/assets/teknisi3.webp" data-fallback="/assets/teknisi3.jpeg" alt="Teknisi mengelas pipa tembaga pada kompresor" decoding="async" width="589" height="1280" />
    <img data-lazy-slide data-src="/assets/teknisi7.webp" data-fallback="/assets/teknisi7.jpeg" alt="Teknisi mengisi refrigeran dengan manifold gauge" decoding="async" width="1920" height="1739" />
  </div>
  <div class="hero-scrim"></div>

  <div class="wrap hero-inner">
    <div class="hero-copy" data-reveal-group>
      <div class="eyebrow"><span class="tick"></span><span class="mono">Sales · Service · Sparepart AC</span></div>
      <h1>Service &amp; jual AC di Mojokerto untuk industri dan hunian.</h1>
      <p class="sub">{site.name} melayani penjualan, pemasangan, servis, dan perawatan AC untuk fasilitas industri maupun rumah tinggal di Mojokerto dan sekitarnya. Dipercaya sejak {site.established} di Jawa Timur.</p>
      <div class="actions">
        <a class="btn btn-light" href="#kontak" data-magnetic>
          Minta Penawaran
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="btn btn-ghost" href="#layanan">Lihat layanan kami →</a>
      </div>
    </div>

    <div class="hero-stats" data-reveal>
      <div class="hs"><b>19+</b><span>Tahun pengalaman</span></div>
      <div class="hs"><b>14+</b><span>Rekanan industri besar</span></div>
    </div>
  </div>
</section>
