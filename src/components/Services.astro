---
import { services } from '../data/site.js';
const icons = [
  `<svg viewBox="0 0 46 46" fill="none" stroke="#1A202C" stroke-width="1.8"><rect x="4" y="13" width="38" height="23" rx="5"/><line x1="24" y1="14" x2="24" y2="35"/><circle cx="14.5" cy="24" r="6.5" stroke-width="1.6"/><circle cx="14.5" cy="24" r="1.3" fill="#1A202C" stroke="none"/><line x1="28" y1="21" x2="38" y2="21" stroke-width="1.3"/><line x1="28" y1="24.5" x2="38" y2="24.5" stroke-width="1.3"/><line x1="28" y1="28" x2="38" y2="28" stroke-width="1.3"/></svg>`,
  `<svg viewBox="0 0 46 46" fill="none" stroke="#1A202C" stroke-width="1.7" stroke-linecap="round"><path d="M23 7 V39 M9 15 L37 31 M37 15 L9 31"/><path d="M23 7 L19.6 10.8 M23 7 L26.4 10.8 M23 39 L19.6 35.2 M23 39 L26.4 35.2 M9 15 L13.4 14.6 M9 15 L9.6 19.4 M37 31 L32.6 31.4 M37 31 L36.4 26.6 M37 15 L32.6 14.6 M37 15 L36.4 19.4 M9 31 L13.4 31.4 M9 31 L9.6 26.6"/></svg>`,
  `<svg viewBox="0 0 46 46" fill="none" stroke="#1A202C" stroke-width="1.8"><rect x="5" y="9" width="36" height="30" rx="5"/><line x1="6.5" y1="18" x2="39.5" y2="18"/><line x1="15.2" y1="5" x2="15.2" y2="12" stroke-linecap="round"/><line x1="30.8" y1="5" x2="30.8" y2="12" stroke-linecap="round"/><path d="M15 28 L20.5 33.5 L31 22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  `<svg viewBox="0 0 46 46" fill="none" stroke="#1A202C" stroke-width="1.8"><circle cx="23" cy="23" r="16"/><path d="M23 13 V23 L30.5 27.5" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>`
];
---
<section id="layanan" class="wrap section">
  <div class="sec-head" data-reveal>
    <div>
      <div class="eyebrow"><span class="tick"></span><span class="mono">Layanan Kami</span></div>
      <h2>Layanan AC menyeluruh, dari penjualan hingga purna jual.</h2>
    </div>
    <div class="right">
      <p>Teknisi berpengalaman dengan pelatihan rutin menangani setiap kebutuhan — penjualan, servis, perawatan berkala, hingga penyewaan unit AC.</p>
      <a class="link" href="#kontak">Konsultasikan kebutuhan Anda →</a>
    </div>
  </div>
  <div class="grid3" data-reveal-group>
    {services.map((s, i) => (
      <div class="cell">
        <div class="ic" set:html={icons[i]} />
        <span class="idx">{s.n}</span>
        <h3>{s.title}</h3>
        <p>{s.desc}</p>
        <a class="link" href="#kontak">Selengkapnya →</a>
      </div>
    ))}
  </div>
</section>
