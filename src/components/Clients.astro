---
import { clients } from '../data/site.js';
---
<section id="rekanan" class="clients-sec">
  <div class="wrap section">
    <div class="sec-head" style="margin-bottom:44px" data-reveal>
      <div>
        <div class="eyebrow"><span class="tick"></span><span class="mono">Rekanan</span></div>
        <h2>Dipercaya perusahaan industri terkemuka.</h2>
      </div>
      <div class="right"><p>Sebagian rekanan CV Ayub Podo Rukun untuk layanan penjualan, servis, dan maintenance AC di Jawa Timur.</p></div>
    </div>
    <div class="cgrid" data-reveal-group>
      {clients.map(c => (
        <div class="c" title={c.name}>
          {c.logo && <img class="c-logo" src={c.logo} alt={`Logo ${c.name}`} loading="lazy" decoding="async" />}
          <b>{c.name}</b>
          <span>{c.loc}</span>
        </div>
      ))}
    </div>
  </div>
</section>
